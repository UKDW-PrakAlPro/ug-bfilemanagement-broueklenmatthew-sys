# --- BAGIAN 2: FUNGSI PARSE WINNER (SESUAI SOAL) ---

def parse_winner(filename):
    try:
        with open(filename, 'r') as file:
            for baris in file:
                baris = baris.strip()
                if not baris:
                    continue
                
                # Memecah baris: [Klub1] [Skor1] - [Skor2] [Klub2]
                bagian = baris.split()
                
                # Mengambil data dari posisi indeks
                nama_klub1 = bagian[0]
                skor_klub1 = int(bagian[1])
                skor_klub2 = int(bagian[3])
                nama_klub2 = bagian[4]
                
                # Menentukan pemenang
                if skor_klub1 > skor_klub2:
                    print(f"Winner: {nama_klub1}")
                elif skor_klub2 > skor_klub1:
                    print(f"Winner: {nama_klub2}")
                else:
                    print("No Winner: Draw")
                    
    except FileNotFoundError:
        print(f"Error: File '{filename}' tidak ditemukan.")

